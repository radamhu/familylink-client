# .envrc — Family Link project (direnv)
# Uses .python-version (3.12), uv for venv, .env for secrets.

# Load .env first (FAMILYLINK_*, etc.)
dotenv_if_exists

# uv: create .venv from .python-version, sync deps
uv sync

# Activate .venv
export VIRTUAL_ENV=$PWD/.venv
export VIRTUAL_ENV_PROMPT="familylink-client"
PATH_add "$VIRTUAL_ENV/bin"

# Project
export PROJECT_ROOT=$PWD
export PYTHONPATH="${PROJECT_ROOT}/src:${PYTHONPATH}"

# Optional overrides (defaults; override in .env)
export LOG_LEVEL=${LOG_LEVEL:-INFO}

echo "familylink — $(python --version 2>&1) | venv: .venv | root: $PROJECT_ROOT"
