# .env.example — copy to .env and fill in (Family Link app env)
# .env is gitignored; use for local secrets.

# ------------------------------------------
# Family Link server (familylink_server)
# ------------------------------------------

# PostgreSQL connection string (asyncpg driver)
# Example: postgresql+asyncpg://user:password@localhost/familylink
DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# Secret key for session signing (generate: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=<random 32-byte hex>

# Google OAuth 2.0 credentials (from Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=<your-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-client-secret>

# Parent Google account email used to fetch Family Link data
FAMILYLINK_GOOGLE_EMAIL=parent@gmail.com

# Base64-encoded cookies for Family Link authentication
# Generate: familylink export-cookies --base64
FAMILYLINK_COOKIES_B64=<base64 output>

# Cache TTL in seconds (default: 900 = 15 minutes)
CACHE_TTL_SECONDS=900

# ------------------------------------------
# Family Link client (client.py)
# ------------------------------------------

# Browser for cookies: firefox | chrome | txt
# txt = cookies from file only (no browser); use with FAMILYLINK_COOKIE_FILE or ./cookies.txt
# FAMILYLINK_BROWSER=firefox

# Cookie file path (overrides --cookie-file when set)
# FAMILYLINK_COOKIE_FILE=/path/to/cookies.txt

# Raw SAPISID value (optional; usually from cookies)
# FAMILYLINK_SAPISID=

# Profile-based / Docker: when cwd is under this dir, use sapisid.txt / cookies.txt in cwd
# FAMILYLINK_PROFILES_DIR=/path/to/profiles

# AuthUser (account index) for multi-account; default 0
# FAMILYLINK_AUTHUSER=0

# ------------------------------------------
# Optional (dev/debug)
# ------------------------------------------

# LOG_LEVEL=INFO
# ENVIRONMENT=development
# DEBUG=False
