# .env.example — copy to .env and fill in (Family Link app env)
# .env is gitignored; use for local secrets.

# ------------------------------------------
# Family Link server (familylink_server)
# ------------------------------------------

# PostgreSQL password (used by docker-compose for both the db service and DATABASE_URL)
# Generate: python -c "import secrets; print(secrets.token_hex(16))"
POSTGRES_PASSWORD=<random password>

# PostgreSQL connection string (asyncpg driver)
# In Docker this is set automatically from POSTGRES_PASSWORD; override only for external DBs.
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# Secret key for session signing (generate: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=<random 32-byte hex>

# Google OAuth 2.0 credentials (from Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=<your-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-client-secret>

# Parent Google account email used to fetch Family Link data
FAMILYLINK_GOOGLE_EMAIL=parent@gmail.com

# Base64-encoded cookies for Family Link authentication
# Generate: familylink export-cookies --base64
FAMILYLINK_COOKIES_B64=<base64 output>

# Cache TTL in seconds (default: 900 = 15 minutes)
CACHE_TTL_SECONDS=900

# ------------------------------------------
# Family Link client (client.py)
# ------------------------------------------

# Browser for cookies: firefox | chrome | txt
# txt = cookies from file only (no browser); use with FAMILYLINK_COOKIE_FILE or ./cookies.txt
# FAMILYLINK_BROWSER=firefox

# Cookie file path (overrides --cookie-file when set)
# FAMILYLINK_COOKIE_FILE=/path/to/cookies.txt

# Raw SAPISID value (optional; usually from cookies)
# FAMILYLINK_SAPISID=

# Profile-based / Docker: when cwd is under this dir, use sapisid.txt / cookies.txt in cwd
# FAMILYLINK_PROFILES_DIR=/path/to/profiles

# AuthUser (account index) for multi-account; default 0
# FAMILYLINK_AUTHUSER=0

# ------------------------------------------
# Optional (dev/debug)
# ------------------------------------------

# LOG_LEVEL=INFO
# ENVIRONMENT=development

# Set to true for local Docker development ONLY.
# Disables the Secure flag on the session cookie so it works over plain HTTP (localhost).
# Never enable in production.
# DEBUG=false

# ------------------------------------------
# Discord bot (optional — all three required to enable)
# ------------------------------------------

# Bot token from Discord Developer Portal → Bot → Token
# DISCORD_BOT_TOKEN=

# Discord server (guild) ID (enable Developer Mode → right-click server → Copy ID)
# DISCORD_GUILD_ID=

# Channel ID for outbound notifications (right-click channel → Copy ID)
# DISCORD_CHANNEL_ID=

# Name of the Discord role allowed to run bot commands (default: Parent)
# DISCORD_ALLOWED_ROLE=Parent

# Daily summary time in HH:MM UTC (default: 20:00)
# DISCORD_SUMMARY_TIME=20:00

# ------------------------------------------
# Coolify integration (optional — used by `familylink export-cookies --coolify`)
# ------------------------------------------

# Base URL of your Coolify instance
# COOLIFY_URL=http://192.168.0.22:8000

# Coolify API bearer token (Settings → API Tokens)
# COOLIFY_TOKEN=<your-token>

# UUID of the familylink-client application in Coolify
# (visible in the app URL: /project/.../application/<uuid>)
# COOLIFY_APP_UUID=<your-app-uuid>
