{
    "version": 1,
    "disable_existing_loggers": false,
    "handlers": {
        "console": {
            "class": "rich.logging.RichHandler",
            "rich_tracebacks": true,
            "markup": true,
            "show_time": true,
            "show_path": false
        }
    },
    "loggers": {
        "uvicorn": {
            "handlers": ["console"],
            "level": "INFO",
            "propagate": false
        },
        "uvicorn.access": {
            "handlers": ["console"],
            "level": "INFO",
            "propagate": false
        },
        "uvicorn.error": {
            "handlers": ["console"],
            "level": "INFO",
            "propagate": false
        },
        "familylink": {
            "handlers": ["console"],
            "level": "INFO",
            "propagate": false
        },
        "familylink_server": {
            "handlers": ["console"],
            "level": "INFO",
            "propagate": false
        },
        "alembic": {
            "handlers": ["console"],
            "level": "INFO",
            "propagate": false
        },
        "sqlalchemy.engine": {
            "handlers": ["console"],
            "level": "WARNING",
            "propagate": false
        }
    },
    "root": {
        "handlers": ["console"],
        "level": "INFO"
    }
}
